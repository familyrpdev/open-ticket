        "dmMessage": {
            "enabled": false,
            "text": "Thank you for creating a ticket in our server! (or leave empty)",
            "embed": {
                "enabled": false,
                "title": "Embed Title! (or leave empty)",
                "description": "Description (or leave empty)",
                "customColor": "",
