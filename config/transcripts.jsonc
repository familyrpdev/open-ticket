/*
 * transcripts.jsonc — FamilyRP [IGUAL fmly]
 * Modo HTML, canal global y DM al creador habilitados.
 *
 * CORE — Open Ticket envía transcripts aquí (canal global + DM al creador).
 *
 * [PLUGIN] ot-transcript-channel
 *   Además envía copia al canal transcriptId de cada opción (options.jsonc).
 */
{
    "general":{
        "enabled":true,

        "enableChannel":true, // [IGUAL fmly]
        "enableCreatorDM":true, // [IGUAL fmly]
        "enableParticipantDM":false,
        "enableActiveAdminDM":false,
        "enableEveryAdminDM":false,

        "channel":"1425797546873196645", // [IGUAL fmly]
        "mode":"html"
    },
    "embedSettings":{
        "customColor":"",
        "listAllParticipants":true,
        "includeTicketStats":true
    },
    "textTranscriptStyle":{
        "layout":"detailed",
        "includeStats":true,
        "includeIds":true,
        "includeEmbeds":true,
        "includeFiles":true,
        "includeBotMessages":true,

        "fileMode":"channel-id",
        "customFileName":""
    },
    "htmlTranscriptStyle":{
        "background":{
            "enableCustomBackground":false,
            "backgroundColor":"",
            "backgroundImage":"" 
        },
        "header":{
            "enableCustomHeader":false,
            "backgroundColor":"#202225",
            "decoColor":"#f8ba00",
            "textColor":"#ffffff"
        },
        "stats":{
            "enableCustomStats":false,
            "backgroundColor":"#202225",
            "keyTextColor":"#737373",
            "valueTextColor":"#ffffff",
            "hideBackgroundColor":"#40444a",
            "hideTextColor":"#ffffff"
        },
        "favicon":{
            "enableCustomFavicon":false,
            "imageUrl":"https://t.dj-dj.be/favicon.png"
        }
    }
}
